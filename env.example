# Frontend Environment Variables
# Copy this file to .env.local and update values as needed

# Backend API URL
NEXT_PUBLIC_API_URL=https://backend.com/api

# For local development, you can override with:
# NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Google Gemini API Key for Nano Banana Pro image generation
# Get your API key from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Backend Environment Variables
# ============================================
# These go in the backend/.env file

# UPI Payment Configuration (for escrow payment system)
# UPI_VPA=groupo@hdfc
# UPI_DISPLAY_NAME=Groupo